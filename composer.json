{
    "name": "arnautdev/filament-deploy-indicator",
    "description": "Show application ENV and latest deployment info inside your Filament admin.",
    "keywords": [
        "arnautdev",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-env",
        "filament-deploy-info",
        "filament-deploy-indicator"
    ],
    "homepage": "https://github.com/arnautdev/filament-deploy-indicator",
    "support": {
        "issues": "https://github.com/arnautdev/filament-deploy-indicator/issues",
        "source": "https://github.com/arnautdev/filament-deploy-indicator"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Dmitry Arnaut",
            "email": "dmitrii.arnaut@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Arnautdev\\FilamentDeployIndicator\\": "src/",
            "Arnautdev\\FilamentDeployIndicator\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arnautdev\\FilamentDeployIndicator\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@php ./vendor/bin/testbench package:discover --ansi"
        ],
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run",
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arnautdev\\FilamentDeployIndicator\\FilamentDeployIndicatorServiceProvider"
            ],
            "aliases": {
                "FilamentDeployIndicator": "Arnautdev\\FilamentDeployIndicator\\Facades\\FilamentDeployIndicator"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
